<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Logs estruturados em JSON (com MDC) — padrão para execução em container -->
    <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdc>true</includeMdc>
            <customFields>{"service":"matricula-process"}</customFields>
        </encoder>
    </appender>

    <!-- Logs legíveis para desenvolvimento local: rodar com SPRING_PROFILES_ACTIVE=local -->
    <appender name="PLAIN" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level [%thread] %logger{36} [%X{correlationId}] [%X{businessKey}] - %msg%n</pattern>
        </encoder>
    </appender>

    <springProfile name="local">
        <root level="INFO">
            <appender-ref ref="PLAIN"/>
        </root>
    </springProfile>

    <springProfile name="!local">
        <root level="INFO">
            <appender-ref ref="JSON"/>
        </root>
    </springProfile>

</configuration>
